{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [
    ".env"
  ],
  "globalEnv": [
    "STELLAR_NETWORK",
    "SOROBAN_RPC_URL",
    "FRONTEND_BASE_URL",
    "BUYER_SECRET_KEY",
    "MERCHANT_ADDRESS",
    "ESCROW_CONTRACT_ID",
    "ADMIN_API_KEY",
    "REFUND_WEBHOOK_URL",
    "REDIS_URL",
    "CHAT_CAPABILITY_SECRET",
    "CHAT_CAPABILITY_TTL_SECONDS",
    "CHAT_HEARTBEAT_INTERVAL_MS"
  ],
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "public/**"]
    },
    "lint": {},
    "test": {
      "dependsOn": ["^build"]
    }
  }
}
