PORT=3000
MERCHANT_ADDRESS=G...YOUR_TESTNET_ADDRESS
STELLAR_NETWORK=TESTNET
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
ESCROW_CONTRACT_ID=CAEYSVTKTCZYTSMPD7CU3NOFYOO4S5V6LJLGRNV7LKTNZ65N66PCHLMC
BUYER_SECRET_KEY=S...YOUR_TESTNET_SECRET_KEY
FRONTEND_BASE_URL=http://localhost:5181

# Admin API key for gating admin/maintainer endpoints (e.g., /admin/status)
# Generate one with: openssl rand -hex 32
ADMIN_API_KEY=

# Webhook URL for refund alerts (Slack or Discord). When a refund is processed,
# a notification with trade ID and amount is posted to this webhook.
# Leave empty to disable.
REFUND_WEBHOOK_URL=

# ---------------------------------------------------------------------------
# Fraud Detection — lightweight flagging for suspicious cash requests.
# Flags are logged (warn level) and surfaced via GET /api/v1/admin/fraud-flags.
# Flagged requests are NEVER blocked; tune thresholds to reduce false positives.
# ---------------------------------------------------------------------------

# Maximum number of cash requests a single buyer address may create inside the
# sliding window before being flagged.
# Default: 5
FRAUD_MAX_REQUESTS_PER_WINDOW=5

# Width of the sliding window in milliseconds.
# Default: 60000 (1 minute)
FRAUD_WINDOW_MS=60000

# Requests with a single amount exceeding this value (in stroops) are flagged.
# Set to 0 to disable the large-amount check entirely.
# Default: 100000000000 (1 000 000 XLM-equivalent)
FRAUD_LARGE_AMOUNT_STROOPS=100000000000

# Comma-separated Stellar buyer addresses that bypass all fraud checks.
# Use for known-good programmatic integrations or batch scripts.
# Example: FRAUD_BUYER_ALLOWLIST=GABC...,GXYZ...
FRAUD_BUYER_ALLOWLIST=
